# ─── Firebase Client ──────────────────────────────────────
# Dapatkan dari: Firebase Console → Project Settings → Web App → Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Firebase Admin SDK ───────────────────────────────────
# Dapatkan dari: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Salin private key dari JSON, ubah \n menjadi literal newline atau gunakan \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Cloudinary (File Storage) ───────────────────────────
# Dapatkan dari: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# ─── AI API Keys ──────────────────────────────────────────
# Google Gemini API Key — dapatkan di: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_api_key_here

# ─── Optional ────────────────────────────────────────────
MODELHUNTER_API_KEY=
